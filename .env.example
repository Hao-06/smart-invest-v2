# ─────────────────────────────────────────────────────────────────
# DeepSeek API 配置 —— 仅**实盘场景**需要；V2 回测/演示 offline 模式不调 LLM
# ─────────────────────────────────────────────────────────────────
# 申请地址：https://platform.deepseek.com/
#
# 🟢 仅以下场景才需要配置 key：
#    - python main.py recommend --date <D> --use-llm   （实盘 R1 推理）
#    - 看板 Tab 3 勾选「启用 LLM 推理(R1)」
#
# 🔵 不需要 key 的场景（评委默认体验路径）：
#    - 所有回测：python main.py validate / bash scripts/run_v2_regions.sh
#    - 看板 Tab 1 业绩长卷 / Tab 2 决策审计 / Tab 3 默认 offline 模式
#
# ⚠️ 本文件是模板，会被 git 追踪。
# 真实 key 请填到同目录下的 .env 文件（已被 .gitignore 屏蔽）。
# ─────────────────────────────────────────────────────────────────

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型选型（V2 实盘模式下 regime / weight allocator 都用 deep = R1）
DEEPSEEK_FAST_MODEL=deepseek-chat
DEEPSEEK_DEEP_MODEL=deepseek-reasoner

# LLM 提供方（可扩展为 claude / minimax 等）
LLM_PROVIDER=deepseek
